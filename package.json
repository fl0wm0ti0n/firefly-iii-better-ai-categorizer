{
  "name": "firefly-iii-ai-categorize",
  "version": "1.0.0",
  "description": "AI-powered transaction categorization for Firefly III with advanced features including drag & drop interface, auto-categorization, and word mappings",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon --inspect=0.0.0.0:9229 index.js",
    "dev:local": "nodemon index.js",
    "docker:build": "docker build -t firefly-categorizer .",
    "docker:run": "echo 'Production: cd /workdir/firefly && docker compose up -d categorizer' && exit 1",
    "docker:standalone": "docker compose --profile standalone-dev up -d",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:stop": "docker compose down --remove-orphans 2>/dev/null; cd /workdir/firefly && docker compose stop categorizer",
    "docker:logs": "docker-compose logs -f",
    "test": "bash tests/run-tests.sh"
  },
  "keywords": [
    "firefly-iii",
    "ai",
    "categorization",
    "openai",
    "finance",
    "automation",
    "drag-drop",
    "transaction-management"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "csv-parse": "^5.5.6",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.2",
    "openai": "^4.104.0",
    "pdf-parse": "^1.1.1",
    "queue": "^7.0.0",
    "socket.io": "^4.6.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
