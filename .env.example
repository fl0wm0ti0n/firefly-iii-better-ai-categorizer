# =============================================================================
# Firefly III AI Categorizer — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# Required variables MUST be set for the service to function.
# Optional variables have sensible defaults shown after the = sign.
# =============================================================================

# --- Required: Firefly III API connection ---

# Base URL of your Firefly III instance (no trailing slash)
# Example: https://firefly.example.com
FIREFLY_URL=

# Personal API token from Firefly III → Profile → OAuth → Personal Access Token
FIREFLY_PERSONAL_TOKEN=

# --- Required: OpenAI API ---

# OpenAI API key for AI classification (starts with sk-...)
OPENAI_API_KEY=

# --- Optional: OpenAI model selection ---

# Model to use for classification (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# --- Optional: UI and server ---

# Enable the admin web UI (true to serve the browser interface)
ENABLE_UI=true

# Container-internal port (the app listens on this inside the container)
# For local compose launch, host maps 3001→3000 via docker-compose.local.yml
PORT=3000

# --- Optional: Data and tagging ---

# Tag applied to categorized transactions (default: AI-categorized)
FIREFLY_TAG=AI-categorized

# Directory for persistent data (config, cache, reviews)
DATA_DIR=./data
